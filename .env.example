# Copy this file to `.env` and fill in values. `.env` is git-ignored — never commit real keys.

# --- Firecrawl MCP -----------------------------------------------------------
# Web scraping/crawling. Used for the RC.org capture (Phase 1+) and research spikes.
# Get a key: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# --- Figma MCP ---------------------------------------------------------------
# No key here. The Figma MCP server uses interactive OAuth.
# In Claude Code, run `/mcp` and authenticate the `figma` server once.

# --- Playwright MCP ----------------------------------------------------------
# No key required.
